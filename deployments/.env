# eBPF Monitoring - Environment Configuration
# Copy from .env.example and customize for your environment

# Frontend UI Configuration
UI_PORT=3000
PROMETHEUS_URL=http://localhost:9090

# Prometheus Configuration
PROMETHEUS_PORT=9090

# PostgreSQL Configuration
POSTGRES_USER=epbf
POSTGRES_PASSWORD=epbf_password
POSTGRES_DB=epbf
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# Database Configuration (for application)
DB_HOST=localhost
DB_PORT=5432
DB_USER=epbf
DB_PASSWORD=epbf_password
DB_NAME=epbf

# Garage S3 Configuration
GARAGE_ADMIN_TOKEN=GK8e70132f9358b127814234a9
GARAGE_SECRET_KEY=e5a68f78406296f9f1f89b1a4fc5169e4f2f2182a031db49d98a728e6ffb3352
GARAGE_REGION=garage
GARAGE_BUCKET=epbf-plugins
GARAGE_PORT=3900
GARAGE_HOST=host.docker.internal

# S3 Configuration (for application)
S3_ENDPOINT=http://127.0.0.1:3900
S3_ACCESS_KEY=GK8e70132f9358b127814234a9
S3_SECRET_KEY=e5a68f78406296f9f1f89b1a4fc5169e4f2f2182a031db49d98a728e6ffb3352
S3_BUCKET=epbf-plugins
S3_REGION=garage

# epbf-monitor Server Configuration
MONITOR_PORT=8080
MONITOR_LOG_LEVEL=info
ENABLE_DOCKER=true
BUILD_DIR=/tmp/epbf-builds
BUILDER_IMAGE=epbf-monitor-builder:latest

# Docker Build Configuration
GO_VERSION=1.25
CLANG_VERSION=14

# Volume Paths
POSTGRES_DATA_PATH=./postgres/data
GARAGE_DATA_PATH=./garage/data
PLUGINS_PATH=../plugins

# Network Configuration
NETWORK_MODE=bridge

# Resource Limits
MEMLOCK_LIMIT=-1

# Security Configuration
PRIVILEGED_MODE=true
CAP_ADD=SYS_ADMIN,BPF,PERFMON,IPC_LOCK

# Health Check Configuration
POSTGRES_HEALTH_INTERVAL=5s
POSTGRES_HEALTH_TIMEOUT=5s
POSTGRES_HEALTH_RETRIES=5

GARAGE_HEALTH_INTERVAL=10s
GARAGE_HEALTH_TIMEOUT=5s
GARAGE_HEALTH_RETRIES=3

# Restart Policy
RESTART_POLICY=unless-stopped
