# =============================================================================
# eBPF Monitoring - Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=epbf
POSTGRES_PASSWORD=epbf_password
POSTGRES_DB=epbf
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# -----------------------------------------------------------------------------
# Garage S3 Configuration
# -----------------------------------------------------------------------------
GARAGE_ADMIN_TOKEN=GKfa5b35bb8a522ebb83c006b8
GARAGE_SECRET_KEY=921529f4512a60d4f2e947a149f5289fb3ade82c1c10f0761397f80b328d682f
GARAGE_REGION=garage
GARAGE_BUCKET=epbf-plugins
GARAGE_PORT=3900
GARAGE_HOST=host.docker.internal

# -----------------------------------------------------------------------------
# epbf-monitor Server Configuration
# -----------------------------------------------------------------------------
MONITOR_PORT=8080
MONITOR_LOG_LEVEL=info

# Build configuration
ENABLE_DOCKER=true
BUILD_DIR=/tmp/epbf-builds
BUILDER_IMAGE=epbf-monitor-builder:latest

# -----------------------------------------------------------------------------
# Docker Build Configuration
# -----------------------------------------------------------------------------
GO_VERSION=1.25
CLANG_VERSION=14

# -----------------------------------------------------------------------------
# Volume Paths (customize for your system)
# -----------------------------------------------------------------------------
POSTGRES_DATA_PATH=./postgres/data
GARAGE_DATA_PATH=./garage/data
PLUGINS_PATH=../plugins

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------
NETWORK_MODE=bridge
# Set to "host" for garage to use host network (required for garage)

# -----------------------------------------------------------------------------
# Resource Limits
# -----------------------------------------------------------------------------
MEMLOCK_LIMIT=-1
# Set to -1 for unlimited, or specify bytes (e.g., 67108864 for 64MB)

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
PRIVILEGED_MODE=true
# Set to false for production with proper capabilities

# Capabilities to add (comma-separated)
CAP_ADD=SYS_ADMIN,BPF,PERFMON,IPC_LOCK

# -----------------------------------------------------------------------------
# Health Check Configuration
# -----------------------------------------------------------------------------
POSTGRES_HEALTH_INTERVAL=5s
POSTGRES_HEALTH_TIMEOUT=5s
POSTGRES_HEALTH_RETRIES=5

GARAGE_HEALTH_INTERVAL=10s
GARAGE_HEALTH_TIMEOUT=5s
GARAGE_HEALTH_RETRIES=3

# -----------------------------------------------------------------------------
# Restart Policy
# -----------------------------------------------------------------------------
RESTART_POLICY=unless-stopped
# Options: no, on-failure, always, unless-stopped
